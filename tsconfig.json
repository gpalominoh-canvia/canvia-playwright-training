{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",

    "paths": {
      "@pom/*": ["src/nivel-2-pom/*"],
      "@screenplay/*": ["src/nivel-3-screenplay/*"],
      "@api/*": ["src/nivel-6-api/*"]
    }
  },
  "include": ["src", "tests", "playwright.config.ts"]
}
